# Server
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# Database — separate database on the existing tonebreak postgres container.
# In Docker compose this resolves via the shared network: postgres:5432.
# In local dev: postgresql://playback:localdev@localhost:5432/playback
DATABASE_URL=postgresql://playback:CHANGEME@postgres:5432/playback

# Auth — devices identify themselves with a static install token. Generate
# one per device on first launch (UUID is fine) and store in iOS keychain.
# This list is regenerated whenever a device is revoked.
INSTALL_TOKEN_PEPPER=replace-with-32-random-bytes-hex

# External API keys
TMDB_API_KEY=
FANART_API_KEY=
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USER_AGENT=Playback v0.1

# Real-Debrid: token is supplied per-user via /me endpoint, not server-side.

# CORS — only the iOS app uses this in production (no browser), but keep
# permissive for local web debugging.
CORS_ORIGIN=*
